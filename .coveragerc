[run]
source =
    linkforge.core
    linkforge.blender
branch = True
parallel = True
relative_files = True

[paths]
source =
    core/src/linkforge/core
    platforms/blender/src/linkforge/blender
    */linkforge/core
    */linkforge/blender

[report]
exclude_lines =
    pragma: no cover
    if typing.TYPE_CHECKING:
    if not typing.TYPE_CHECKING:
    if TYPE_CHECKING:
    \.\.\.
